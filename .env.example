# ──────────────────────────────────────────────────────────────────────────────
# SURL — .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Core Application ──────────────────────────────────────────────────────────
DEBUG=False
PROJECT_NAME="Sentinel URL (SURL)"
VERSION=1.0.0

# Port the API container binds on (used by docker-compose)
API_PORT=8000

# ── Threat Intelligence APIs ──────────────────────────────────────────────────
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# URLhaus: https://urlhaus-api.abuse.ch/
URLHAUS_API_KEY=your_urlhaus_key_here

# ── Storage ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (leave empty to skip DB features)
# Example: postgresql://user:password@localhost:5432/surl
DATABASE_URL=

# ── Object Storage (MinIO / AWS S3) ──────────────────────────────────────────
# Uncomment and fill these if you want screenshot uploads to S3/MinIO
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET_NAME=surl-screenshots

# ── Async Workers (Celery + Redis) ────────────────────────────────────────────
# Required only if the optional Celery worker is enabled
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max scan requests per minute per client IP (0 = disabled)
RATE_LIMIT_PER_MINUTE=30
